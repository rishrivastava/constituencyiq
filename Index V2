// ════ IVRS ════════════════════════════════════════════════════════════════
function buildCallsData() {
  var statuses = ["done","done","busy","miss","pend","done","miss","pend","done","busy"];
  var names = G.rows.slice(0,30).map(function(r, i) {
    return {name:r.Name, ward:r.Ward, issue:r.Problem, phone:r.Phone, status:statuses[i%statuses.length], script:"", support:r.Support};
  });
  G.callsData = names;
}

function renderIVRS() {
  var total = G.callsData.length;
  var done = G.callsData.filter(function(c) { return c.status === "done"; }).length;
  var miss = G.callsData.filter(function(c) { return c.status === "miss"; }).length;
  var pend = G.callsData.filter(function(c) { return c.status === "pend"; }).length;
  var ivrsStats = [{v:total,l:"Total Calls"},{v:done,l:"Completed"},{v:miss,l:"No Answer"},{v:pend,l:"Pending"}];
  var isHtml = "";
  ivrsStats.forEach(function(s) {
    isHtml += "<div class=\"stat\"><div class=\"stat-val\">" + s.v + "</div><div class=\"stat-lbl\">" + s.l + "</div></div>";
  });
  document.getElementById("ivrs-stats").innerHTML = isHtml;
  filterCalls();
}

function filterCalls() {
  var filter = document.getElementById("call-filter").value;
  var search = (document.getElementById("call-search").value || "").toLowerCase();
  var filtered = G.callsData.filter(function(c) {
    return (!filter || c.status === filter) && (!search || c.name.toLowerCase().indexOf(search) >= 0);
  });
  var clHtml = "";
  var smap2 = {done:"cs-done",busy:"cs-busy",miss:"cs-miss",pend:"cs-pend"};
  var slabel2 = {done:"Completed",busy:"Busy",miss:"No Answer",pend:"Pending"};
  filtered.forEach(function(c, i) {
    clHtml += "<div class=\"call-item\">";
    clHtml += "<div class=\"call-status " + smap2[c.status] + "\">" + slabel2[c.status] + "</div>";
    clHtml += "<div style=\"flex:1\"><div class=\"call-name\">" + c.name + "</div><div class=\"call-meta\">" + c.ward + " &middot; " + c.issue + "</div></div>";
    clHtml += "<button class=\"btn btn-dim btn-xs\" onclick=\"viewScript(" + i + ")\">Script</button>";
    clHtml += "</div>";
  });
  document.getElementById("calls-list").innerHTML = clHtml;
}


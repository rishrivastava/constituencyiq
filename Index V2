// ════ CHAT ════════════════════════════════════════════════════════════════
function nt() { return new Date().toLocaleTimeString([], {hour:"2-digit",minute:"2-digit"}); }

function addBubble(role, txt) {
  var c = document.getElementById("chat-msgs");
  var row = document.createElement("div");
  row.className = "msg-row " + role;
  if (role === "b") {
    var av = document.createElement("div");
    av.className = "msg-av-b";
    av.textContent = "AI";
    var bwrap = document.createElement("div");
    var bub = document.createElement("div");
    bub.className = "bubble b";
    bub.innerHTML = txt.replace(/\n/g, "<br>") + '<div class="btime">' + nt() + "</div>";
    bwrap.appendChild(bub);
    row.appendChild(av);
    row.appendChild(bwrap);
  } else {
    var bwrap2 = document.createElement("div");
    var bub2 = document.createElement("div");
    bub2.className = "bubble u";
    bub2.innerHTML = txt.replace(/\n/g, "<br>") + '<div class="btime">' + nt() + "</div>";
    bwrap2.appendChild(bub2);
    row.appendChild(bwrap2);
  }
  c.appendChild(row);
  c.scrollTop = c.scrollHeight;
  updateChips();
}

function showTyping() {
  var c = document.getElementById("chat-msgs");
  var row = document.createElement("div");
  row.className = "msg-row b"; row.id = "typing-row";
  var av = document.createElement("div");
  av.className = "msg-av-b"; av.textContent = "AI";
  var bwrap = document.createElement("div");
  var typ = document.createElement("div");
  typ.className = "typing-ind";
  typ.innerHTML = '<div class="dot"></div><div class="dot"></div><div class="dot"></div>';
  bwrap.appendChild(typ);
  row.appendChild(av); row.appendChild(bwrap);
  c.appendChild(row); c.scrollTop = c.scrollHeight;
}
function rmTyping() { var e = document.getElementById("typing-row"); if (e) e.remove(); }

function updateChips() {
  var chips = G.lang === "hi"
    ? ["Lucknow West summary", "Sabse bada issue kya hai?", "Muslim voter strategy", "SP 2022 mein kaise jeeta?", "Win karne ke liye kya karein?", "OBC voters ka mood"]
    : ["Lucknow West summary", "Biggest issue?", "How did SP win 2022?", "Muslim voter strategy", "Key actions to win", "OBC voter mood"];
  var chHtml = "";
  chips.forEach(function(c) {
    chHtml += "<div class=\"chip\" onclick=\"quickMsg(this)\">" + c + "</div>";
  });
  document.getElementById("chat-chips").innerHTML = chHtml;
}

function quickMsg(el) {
  document.getElementById("chat-inp").value = el.textContent;
  sendMsg();
}

async function sendMsg() {
  if (G.busy) return;
  var inp = document.getElementById("chat-inp");
  var txt = inp.value.trim();
  if (!txt) return;
  inp.value = "";
  addBubble("u", txt);
  G.chatHist.push({role:"user", content:txt});
  G.busy = true;
  document.getElementById("chat-st").textContent = "typing...";
  showTyping();
  try {
    var langInstruction = G.lang === "hi"
      ? "IMPORTANT: Always respond in professional Hindi (Devanagari script). Be formal and respectful."
      : "IMPORTANT: Always respond in clear professional English.";
    var res = await api("chat", {
      message: txt,
      history: G.chatHist.slice(-8).slice(0,-1),
      lang: G.lang,
      systemExtra: langInstruction,
      constituencyData: G.rows.slice(0,20),
      knowledgeBase: G.docsKB
    });
    rmTyping();
    addBubble("b", res.reply);
    G.chatHist.push({role:"assistant", content:res.reply});
  } catch(e) {
    rmTyping();
    addBubble("b", G.lang === "hi" ? "Khed hai, kuch galat hua: " + e.message : "Sorry, error: " + e.message);
  }
  G.busy = false;
  document.getElementById("chat-st").textContent = "Ready";
}

function clearChat() {
  G.chatHist = [];
  document.getElementById("chat-msgs").innerHTML = "";
  addBubble("b", G.lang === "hi" ? "Chat clear ho gaya! Kuch bhi poochho." : "Chat cleared! Ask me anything.");
}


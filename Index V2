<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1"/>
<title>ConstituencyIQ — AI Political Intelligence</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.0/firebase-auth-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.0/firebase-firestore-compat.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}

/* ── THEMES ── */
:root{
  --bg:#06090f;--s1:#0b0f1a;--s2:#0f1520;--s3:#141c2a;--s4:#1a2336;
  --border:#1e3250;--border2:#243b5a;
  --gold:#f0a500;--gold2:#e09000;--gold3:#fbbf24;
  --accent:#f0a500;--accent2:#e09000;
  --red:#ef4444;--green:#10b981;--blue:#2563eb;--cyan:#06b6d4;--purple:#7c3aed;
  --text:#eef2ff;--text2:#94a3b8;--text3:#64748b;--text4:#475569;
  --font-head:"Syne",sans-serif;--font-body:"DM Sans",sans-serif;
  --radius:10px;--radius2:14px;--shadow:0 8px 32px #00000050;
}
[data-theme="warroom"]{
  --bg:#050508;--s1:#090910;--s2:#0d0d16;--s3:#12121e;--s4:#181828;
  --border:#2a1a2e;--border2:#3a1a3e;
  --accent:#dc2626;--accent2:#b91c1c;
  --gold:#f0a500;--gold2:#e09000;
  --text:#fff0f0;--text2:#fca5a5;--text3:#ef9999;
}
[data-theme="light"]{
  --bg:#f1f5f9;--s1:#ffffff;--s2:#f8fafc;--s3:#f1f5f9;--s4:#e2e8f0;
  --border:#cbd5e1;--border2:#94a3b8;
  --text:#0f172a;--text2:#334155;--text3:#64748b;
  --accent:#f0a500;--accent2:#e09000;
}

html,body{height:100%;background:var(--bg);color:var(--text);font-family:var(--font-body);overflow:hidden;font-size:14px}
::-webkit-scrollbar{width:3px;height:3px}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}
::-webkit-scrollbar-track{background:transparent}

@keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
@keyframes glow{0%,100%{box-shadow:0 0 8px #f0a50033}50%{box-shadow:0 0 22px #f0a50066}}
@keyframes slideIn{from{transform:translateX(-8px);opacity:0}to{transform:translateX(0);opacity:1}}

/* ── LOGIN ── */
.login-wrap{position:fixed;inset:0;display:flex;align-items:center;justify-content:center;background:var(--bg);z-index:999;animation:fadeIn .4s ease}
.login-bg{position:absolute;inset:0;background:radial-gradient(ellipse at 30% 40%,#f0a50008 0%,transparent 60%),radial-gradient(ellipse at 70% 70%,#2563eb08 0%,transparent 60%)}
.login-card{position:relative;width:100%;max-width:400px;margin:20px;background:var(--s2);border:1px solid var(--border);border-radius:20px;padding:40px 36px;box-shadow:0 30px 80px #00000070,inset 0 1px 0 #ffffff08}
.login-logo{text-align:center;margin-bottom:32px}
.ciq-mark{display:inline-flex;align-items:baseline;gap:1px;margin-bottom:10px}
.ciq-c{font-family:var(--font-head);font-size:44px;font-weight:800;letter-spacing:3px;background:linear-gradient(135deg,var(--gold),var(--gold3),var(--gold2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1}
.ciq-iq{font-family:var(--font-head);font-size:22px;font-weight:700;background:linear-gradient(135deg,var(--gold2),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1;margin-bottom:6px}
.login-title{font-family:var(--font-head);font-size:13px;font-weight:600;color:var(--text3);letter-spacing:2px;text-transform:uppercase}
.login-sub{font-size:11px;color:var(--text3);margin-top:4px}
.l-group{margin-bottom:14px}
.l-label{font-size:10px;font-weight:600;color:var(--text3);letter-spacing:.8px;text-transform:uppercase;margin-bottom:5px;display:block}
.l-input{width:100%;background:var(--bg);border:1px solid var(--border2);border-radius:8px;padding:11px 14px;color:var(--text);font-size:13px;font-family:var(--font-body);outline:none;transition:border .2s,box-shadow .2s}
.l-input:focus{border-color:#f0a50055;box-shadow:0 0 0 3px #f0a50010}
.l-btn{width:100%;background:linear-gradient(135deg,var(--gold),var(--gold2));border:none;border-radius:8px;padding:12px;font-family:var(--font-head);font-size:13px;font-weight:700;color:#000;cursor:pointer;letter-spacing:.5px;transition:all .2s;margin-top:6px}
.l-btn:hover{filter:brightness(1.08);transform:translateY(-1px)}
.l-btn:disabled{opacity:.5;cursor:not-allowed;transform:none}
.l-err{background:#ef444415;border:1px solid #ef444430;border-radius:7px;padding:9px 12px;color:var(--red);font-size:12px;margin-bottom:12px;display:none}
.l-spin{width:16px;height:16px;border:2px solid #00000020;border-top-color:#000;border-radius:50%;animation:spin .7s linear infinite;display:inline-block;vertical-align:middle;margin-right:6px}
.l-footer{text-align:center;font-size:11px;color:var(--text3);margin-top:16px}

/* ── SHELL ── */
.shell{display:none;height:100vh;overflow:hidden}
.shell.on{display:flex}

/* ── SIDEBAR ── */
.sidebar{width:220px;min-width:200px;background:var(--s1);border-right:1px solid var(--border);display:flex;flex-direction:column;transition:width .3s;flex-shrink:0;position:relative}
.sidebar.collapsed{width:52px;min-width:52px}
.sb-head{padding:16px 14px 12px;border-bottom:1px solid var(--border);background:linear-gradient(160deg,var(--s3),var(--s1))}
.sb-brand{display:flex;align-items:center;gap:8px;overflow:hidden}
.sb-ciq{display:inline-flex;align-items:baseline;gap:1px;flex-shrink:0}
.sb-c{font-family:var(--font-head);font-size:20px;font-weight:800;letter-spacing:2px;background:linear-gradient(135deg,var(--gold),var(--gold3));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1}
.sb-iq{font-family:var(--font-head);font-size:11px;font-weight:700;background:linear-gradient(135deg,var(--gold2),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1;margin-bottom:3px}
.sb-name-wrap{overflow:hidden;white-space:nowrap;transition:opacity .2s}
.sidebar.collapsed .sb-name-wrap{opacity:0;width:0}
.sb-fullname{font-family:var(--font-head);font-size:13px;font-weight:700;color:var(--text)}
.sb-tagline{font-size:9px;color:var(--text3);letter-spacing:.5px}
.sb-collapse{position:absolute;right:-10px;top:20px;width:20px;height:20px;background:var(--s3);border:1px solid var(--border);border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:10px;color:var(--text3);z-index:10;transition:all .2s}
.sb-collapse:hover{background:var(--accent);color:#000}
.sb-user{padding:9px 12px;border-bottom:1px solid var(--border);overflow:hidden;white-space:nowrap}
.sidebar.collapsed .sb-user{padding:9px 6px}
.sb-uname{font-size:11px;font-weight:600;color:var(--text);overflow:hidden;text-overflow:ellipsis}
.sb-urole{font-size:10px;color:var(--accent);text-transform:capitalize;font-weight:500}
.sidebar.collapsed .sb-uname,.sidebar.collapsed .sb-urole{display:none}
.sb-scroll{flex:1;overflow-y:auto;padding:6px 5px}
.sb-group{font-size:9px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--text4);padding:10px 9px 3px;white-space:nowrap;overflow:hidden}
.sidebar.collapsed .sb-group{opacity:0}
.nav-btn{display:flex;align-items:center;gap:8px;padding:8px 9px;border-radius:8px;cursor:pointer;margin-bottom:1px;transition:all .15s;font-size:12px;font-weight:500;color:var(--text3);border:none;background:transparent;width:100%;text-align:left;font-family:var(--font-body);white-space:nowrap;overflow:hidden;position:relative}
.nav-btn:hover{background:var(--s3);color:var(--text)}
.nav-btn.on{background:linear-gradient(135deg,#f0a50012,#f0a50006);color:var(--gold);font-weight:600}
.nav-btn.on::before{content:"";position:absolute;left:0;top:4px;bottom:4px;width:2px;background:var(--gold);border-radius:0 2px 2px 0}
[data-theme="warroom"] .nav-btn.on{color:var(--red);background:linear-gradient(135deg,#dc262612,#dc262606)}
[data-theme="warroom"] .nav-btn.on::before{background:var(--red)}
.nav-ic{font-size:14px;width:18px;text-align:center;flex-shrink:0}
.nav-lbl{overflow:hidden;text-overflow:ellipsis;white-space:nowrap;transition:opacity .2s}
.sidebar.collapsed .nav-lbl{opacity:0;width:0}
.nav-hidden{display:none}
.sb-bottom{padding:10px;border-top:1px solid var(--border)}
.logout-btn{width:100%;background:var(--s3);border:1px solid var(--border);border-radius:8px;padding:8px;color:var(--text3);font-size:11px;cursor:pointer;font-family:var(--font-body);transition:all .2s;display:flex;align-items:center;justify-content:center;gap:5px}
.logout-btn:hover{background:#ef444415;color:var(--red);border-color:#ef444430}
.sidebar.collapsed .logout-btn span{display:none}
.data-badge{font-size:10px;color:var(--text3);text-align:center;margin-top:6px;white-space:nowrap;overflow:hidden}
.sidebar.collapsed .data-badge{display:none}

/* ── MAIN ── */
.main{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0}

/* ── TOPBAR ── */
.topbar{background:var(--s1);border-bottom:1px solid var(--border);padding:10px 18px;display:flex;align-items:center;gap:10px;flex-shrink:0;min-height:52px}
.tb-left{display:flex;flex-direction:column}
.tb-title{font-family:var(--font-head);font-size:14px;font-weight:700;color:var(--text)}
.tb-sub{font-size:10px;color:var(--text3);margin-top:1px}
.tb-right{margin-left:auto;display:flex;gap:6px;align-items:center;flex-wrap:wrap}
.pill{font-size:9px;font-weight:700;padding:3px 8px;border-radius:20px;letter-spacing:.6px;text-transform:uppercase;white-space:nowrap}
.pill-gold{background:#f0a50014;color:var(--gold);border:1px solid #f0a50025}
.pill-green{background:#10b98114;color:var(--green);border:1px solid #10b98125}
.pill-blue{background:#2563eb14;color:var(--cyan);border:1px solid #2563eb25}
.pill-red{background:#ef444414;color:var(--red);border:1px solid #ef444425}
.pill-dim{background:var(--s3);color:var(--text3);border:1px solid var(--border)}

/* ── THEME SWITCHER ── */
.theme-sw{display:flex;gap:4px;background:var(--s3);padding:3px;border-radius:8px;border:1px solid var(--border)}
.theme-opt{padding:4px 8px;border-radius:6px;font-size:10px;font-weight:600;cursor:pointer;transition:all .15s;color:var(--text3);border:none;background:transparent;font-family:var(--font-body)}
.theme-opt.on{background:var(--accent);color:#000}
[data-theme="warroom"] .theme-opt.on{color:#fff}

/* ── PANELS ── */
.panel{flex:1;overflow-y:auto;padding:16px 18px;display:none;animation:fadeUp .3s ease}
.panel.on{display:block}
.chat-panel{flex:1;display:none;flex-direction:column;overflow:hidden}
.chat-panel.on{display:flex}

/* ── CARDS ── */
.card{background:var(--s2);border:1px solid var(--border);border-radius:var(--radius2);padding:16px;margin-bottom:12px;position:relative;overflow:hidden}
.card-accent{border-color:#f0a50025}
[data-theme="warroom"] .card-accent{border-color:#dc262625}
.card-title{font-family:var(--font-head);font-size:12px;font-weight:700;color:var(--gold);letter-spacing:.5px;text-transform:uppercase;margin-bottom:10px;display:flex;align-items:center;gap:6px}
[data-theme="warroom"] .card-title{color:var(--red)}
.card-sub{font-size:11px;color:var(--text3);line-height:1.65;margin-bottom:10px}
.card-shine{position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,#f0a50030,transparent)}

/* ── GRID ── */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
.row{display:flex;gap:8px;align-items:center;flex-wrap:wrap}

/* ── STAT CARDS ── */
.stat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:10px;margin-bottom:14px}
.stat{background:var(--s2);border:1px solid var(--border);border-radius:var(--radius);padding:14px;position:relative;overflow:hidden;transition:border .2s}
.stat:hover{border-color:var(--border2)}
.stat::after{content:"";position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--accent),transparent)}
.stat-val{font-family:var(--font-head);font-size:22px;font-weight:800;color:var(--text);line-height:1;margin-bottom:3px}
.stat-lbl{font-size:10px;color:var(--text3);font-weight:500}
.stat-trend{font-size:10px;margin-top:4px;font-weight:600}
.stat-up{color:var(--green)}.stat-dn{color:var(--red)}

/* ── FORM ELEMENTS ── */
.lbl{font-size:10px;font-weight:600;color:var(--text3);letter-spacing:.5px;text-transform:uppercase;margin-bottom:4px;display:block}
.inp{width:100%;background:var(--bg);border:1px solid var(--border2);border-radius:7px;padding:9px 12px;color:var(--text);font-size:12px;font-family:var(--font-body);outline:none;transition:border .2s}
.inp:focus{border-color:#f0a50050}
.sel{width:100%;background:var(--bg);border:1px solid var(--border2);border-radius:7px;padding:9px 12px;color:var(--text);font-size:12px;font-family:var(--font-body);outline:none;cursor:pointer}
.sel option{background:var(--s2)}
.ta{width:100%;background:var(--bg);border:1px solid var(--border2);border-radius:7px;padding:9px 12px;color:var(--text);font-size:12px;font-family:var(--font-body);outline:none;resize:vertical;min-height:72px}

/* ── BUTTONS ── */
.btn{border:none;border-radius:7px;padding:8px 16px;font-weight:600;font-size:12px;cursor:pointer;font-family:var(--font-body);transition:all .15s;display:inline-flex;align-items:center;gap:5px;letter-spacing:.2px}
.btn:hover{filter:brightness(1.1);transform:translateY(-1px)}
.btn:active{transform:scale(.97)}
.btn:disabled{opacity:.4;cursor:not-allowed;transform:none;filter:none}
.btn-gold{background:linear-gradient(135deg,var(--gold),var(--gold2));color:#000;font-weight:700}
.btn-red{background:var(--red);color:#fff}
.btn-green{background:var(--green);color:#000;font-weight:700}
.btn-blue{background:var(--blue);color:#fff}
.btn-dim{background:var(--s3);color:var(--text2);border:1px solid var(--border)}
.btn-sm{padding:6px 12px;font-size:11px}
.btn-xs{padding:4px 8px;font-size:10px}
.btn-purple{background:var(--purple);color:#fff}

/* ── TAGS ── */
.tag{display:inline-flex;align-items:center;font-size:10px;font-weight:600;padding:2px 8px;border-radius:20px;margin:2px}
.tg{background:#f0a50012;color:var(--gold);border:1px solid #f0a50020}
.tb{background:#2563eb12;color:var(--cyan);border:1px solid #2563eb20}
.tgn{background:#10b98112;color:var(--green);border:1px solid #10b98120}
.tr{background:#ef444412;color:var(--red);border:1px solid #ef444420}
.tp{background:#7c3aed12;color:#a78bfa;border:1px solid #7c3aed20}

/* ── AI OUTPUT ── */
.ai-out{background:var(--bg);border:1px solid #2563eb20;border-radius:9px;padding:14px;margin-top:10px;font-size:12px;line-height:1.9;color:var(--text2);white-space:pre-wrap;animation:fadeUp .35s ease}

/* ── PROGRESS BAR ── */
.prog{height:5px;background:var(--s3);border-radius:3px;overflow:hidden;margin-top:4px}
.prog-fill{height:100%;border-radius:3px;transition:width 1.2s cubic-bezier(.4,0,.2,1)}

/* ── TABLE ── */
.tbl-wrap{overflow-x:auto;border-radius:9px;border:1px solid var(--border)}
table{width:100%;border-collapse:collapse;font-size:11px}
th{padding:8px 12px;background:var(--bg);color:var(--gold);text-align:left;border-bottom:1px solid var(--border);font-size:9px;text-transform:uppercase;letter-spacing:.6px;font-weight:700;font-family:var(--font-head)}
td{padding:7px 12px;border-bottom:1px solid #1e325025;color:var(--text2)}
tr:last-child td{border-bottom:none}
tr:hover td{background:var(--s3)30}

/* ── SENTIMENT METER ── */
.meter-wrap{display:flex;flex-direction:column;align-items:center;padding:10px 0}
.meter-gauge{position:relative;width:200px;height:110px;overflow:visible}
.meter-gauge svg{overflow:visible}
.meter-needle{transform-origin:50% 100%;transition:transform 1.8s cubic-bezier(.4,0,.2,1)}
.meter-score{position:absolute;bottom:0;left:50%;transform:translateX(-50%);text-align:center}
.meter-num{font-family:var(--font-head);font-size:36px;font-weight:900;line-height:1}
.meter-lbl{font-size:10px;color:var(--text3);margin-top:2px;font-weight:600;letter-spacing:.5px}
.meter-status{font-family:var(--font-head);font-size:13px;font-weight:700;margin-top:8px;text-align:center}
.meter-trend{font-size:11px;color:var(--text3);text-align:center;margin-top:3px}

/* ── DEMO BAR ── */
.dbar{display:flex;align-items:center;gap:8px;margin-bottom:7px}
.dbar-lbl{font-size:11px;color:var(--text2);width:90px;flex-shrink:0;text-align:right}
.dbar-track{flex:1;height:7px;background:var(--s3);border-radius:4px;overflow:hidden}
.dbar-fill{height:100%;border-radius:4px;transition:width 1.2s ease}
.dbar-val{font-size:11px;font-weight:700;color:var(--text);width:36px;flex-shrink:0}

/* ── CHAT ── */
.chat-top{padding:10px 16px;background:linear-gradient(135deg,#0a3d2e,#0d4a38);border-bottom:1px solid #0f6b5060;display:flex;align-items:center;gap:9px;flex-shrink:0}
[data-theme="warroom"] .chat-top{background:linear-gradient(135deg,#2d0a0a,#3d0d0d);border-color:#6b0f0f60}
.chat-av{width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,var(--gold),var(--gold2));display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:900;color:#000;flex-shrink:0;font-family:var(--font-head)}
.chat-nm{font-size:12px;font-weight:700;color:#fff;font-family:var(--font-head)}
.chat-st{font-size:9px;color:#4ade8060;margin-top:1px}
.lang-sw{margin-left:auto;display:flex;gap:3px;background:#00000020;padding:3px;border-radius:7px}
.lang-opt{padding:4px 9px;border-radius:5px;font-size:10px;font-weight:600;cursor:pointer;transition:all .15s;color:#ffffff70;border:none;background:transparent;font-family:var(--font-body)}
.lang-opt.on{background:#ffffff15;color:#fff}
.chat-msgs{flex:1;overflow-y:auto;padding:14px 16px;background:linear-gradient(180deg,#050a10,#070c14)}
.msg-row{display:flex;margin-bottom:10px;align-items:flex-end;gap:6px;animation:fadeUp .25s ease}
.msg-row.u{justify-content:flex-end}
.msg-av-b{width:22px;height:22px;border-radius:50%;background:linear-gradient(135deg,#0a3d2e,#128C7E);display:flex;align-items:center;justify-content:center;font-size:9px;flex-shrink:0;font-weight:700;color:#fff}
.bubble{max-width:80%;padding:9px 13px;border-radius:13px;font-size:12.5px;line-height:1.65}
.bubble.u{background:linear-gradient(135deg,#004d3d,#005C4B);color:#e9edef;border-radius:13px 13px 3px 13px}
.bubble.b{background:var(--s2);color:var(--text2);border-radius:13px 13px 13px 3px;border:1px solid var(--border)}
.btime{font-size:9px;color:#ffffff25;margin-top:3px;text-align:right}
.bubble.b .btime{color:var(--text4);text-align:left}
.typing-ind{display:flex;gap:4px;padding:9px 13px;background:var(--s2);border-radius:13px 13px 13px 3px;border:1px solid var(--border);width:fit-content}
.dot{width:5px;height:5px;border-radius:50%;background:var(--text3);animation:pulse .9s infinite}
.dot:nth-child(2){animation-delay:.2s}.dot:nth-child(3){animation-delay:.4s}
.chips-row{padding:8px 12px;background:var(--s1);border-top:1px solid var(--border);display:flex;gap:5px;overflow-x:auto;flex-shrink:0}
.chip{background:var(--s3);color:var(--text3);font-size:10px;font-weight:500;padding:5px 10px;border-radius:20px;cursor:pointer;white-space:nowrap;border:1px solid var(--border2);transition:all .15s;flex-shrink:0}
.chip:hover{background:#f0a50012;color:var(--gold);border-color:#f0a50025}
.chat-in-row{padding:10px 12px;background:var(--s1);border-top:1px solid var(--border);display:flex;align-items:center;gap:8px;flex-shrink:0}
.chat-inp{flex:1;background:var(--s3);border:1px solid var(--border2);border-radius:20px;padding:9px 14px;color:var(--text);font-size:12.5px;font-family:var(--font-body);outline:none;transition:border .2s}
.chat-inp:focus{border-color:#f0a50040}
.chat-inp::placeholder{color:var(--text3)}
.send-btn{width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,#00a884,#00c49a);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:15px;transition:transform .2s;flex-shrink:0}
.send-btn:hover{transform:scale(1.08)}

/* ── DEMOGRAPHICS ── */
.demo-tabs{display:flex;gap:4px;background:var(--s3);padding:3px;border-radius:9px;border:1px solid var(--border);margin-bottom:14px;flex-wrap:wrap}
.demo-tab{flex:1;padding:6px 10px;border-radius:7px;font-size:11px;font-weight:600;cursor:pointer;text-align:center;color:var(--text3);border:none;background:transparent;font-family:var(--font-body);white-space:nowrap;transition:all .15s}
.demo-tab.on{background:var(--accent);color:#000}
.demo-content{display:none;animation:fadeUp .25s ease}
.demo-content.on{display:block}
.chart-box{position:relative;max-height:220px;display:flex;align-items:center;justify-content:center;margin-bottom:14px}

/* ── ISSUES ── */
.issue-item{padding:10px 12px;border-bottom:1px solid #1e325025;display:flex;gap:10px;align-items:flex-start;transition:background .15s}
.issue-item:hover{background:var(--s3)50}
.issue-item:last-child{border-bottom:none}
.issue-rank{width:22px;height:22px;border-radius:50%;background:linear-gradient(135deg,var(--gold),var(--gold2));color:#000;font-size:10px;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-family:var(--font-head)}
.issue-title{font-size:12px;font-weight:600;color:var(--text);margin-bottom:2px}
.issue-meta{font-size:10px;color:var(--text3)}
.sev-bar{width:50px;height:4px;border-radius:2px;margin-top:4px}

/* ── TRENDING ── */
.trend-item{padding:10px 12px;border-bottom:1px solid #1e325025;animation:slideIn .3s ease}
.trend-item:last-child{border-bottom:none}
.trend-src{font-size:9px;font-weight:700;padding:2px 6px;border-radius:5px;text-transform:uppercase;letter-spacing:.4px;display:inline-block;margin-bottom:4px}
.trend-text{font-size:12px;color:var(--text);line-height:1.45;margin-bottom:3px}
.trend-meta{font-size:10px;color:var(--text3)}

/* ── WHATSAPP PANEL ── */
.wa-preview{background:#111b21;border-radius:12px;padding:16px;margin-top:10px}
.wa-header{background:#1f2c34;border-radius:9px 9px 0 0;padding:10px 14px;display:flex;align-items:center;gap:8px}
.wa-av{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,#25d366,#128c7e);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:900;color:#fff;font-family:var(--font-head)}
.wa-name{font-size:13px;font-weight:600;color:#e9edef}
.wa-st{font-size:10px;color:#8696a0}
.wa-msgs{background:#0b141a;padding:12px;border-radius:0 0 9px 9px;min-height:120px}
.wa-msg{background:#1f2c34;border-radius:8px 8px 8px 0;padding:8px 12px;margin-bottom:8px;max-width:80%;font-size:12px;color:#e9edef;line-height:1.5}
.wa-msg-time{font-size:9px;color:#8696a0;margin-top:3px}
.wa-qr{background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:16px;text-align:center;margin-top:10px}

/* ── SARVAM / IVRS ── */
.call-item{padding:10px 12px;border-bottom:1px solid #1e325025;display:flex;align-items:center;gap:10px}
.call-item:last-child{border-bottom:none}
.call-status{font-size:10px;font-weight:700;padding:3px 8px;border-radius:20px;flex-shrink:0}
.cs-done{background:#10b98115;color:var(--green);border:1px solid #10b98125}
.cs-busy{background:#f0a50015;color:var(--gold);border:1px solid #f0a50025}
.cs-miss{background:#ef444415;color:var(--red);border:1px solid #ef444425}
.cs-pend{background:var(--s3);color:var(--text3);border:1px solid var(--border)}
.call-name{font-size:12px;font-weight:600;color:var(--text);flex:1}
.call-meta{font-size:10px;color:var(--text3)}

/* ── COMPARISON ── */
.comp-grid{display:grid;gap:10px;margin-bottom:14px}
.comp-head{background:var(--s3);border-radius:9px;padding:10px 14px;text-align:center}
.comp-name{font-family:var(--font-head);font-size:13px;font-weight:700;color:var(--gold);margin-bottom:2px}
.comp-sub{font-size:10px;color:var(--text3)}
.comp-row{display:grid;gap:10px;margin-bottom:7px;align-items:center}
.comp-metric{font-size:11px;color:var(--text3);padding:6px 10px;background:var(--bg);border-radius:7px 0 0 7px;font-weight:600}
.comp-val{font-size:12px;font-weight:700;color:var(--text);padding:6px 10px;background:var(--s3);border-radius:0 7px 7px 0;text-align:center}

/* ── ACTION ITEMS ── */
.action-card{background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:13px;margin-bottom:8px;transition:border .2s;animation:slideIn .3s ease}
.action-card:hover{border-color:#f0a50025}
.action-top{display:flex;gap:9px;align-items:flex-start;margin-bottom:6px}
.action-num{width:22px;height:22px;border-radius:50%;background:linear-gradient(135deg,var(--gold),var(--gold2));color:#000;font-size:10px;font-weight:900;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;font-family:var(--font-head)}
.action-title{font-size:12px;font-weight:700;color:var(--text);line-height:1.35}
.action-body{font-size:11px;color:var(--text3);line-height:1.65;padding-left:31px}
.impact-tag{display:inline-flex;align-items:center;font-size:10px;font-weight:700;padding:2px 8px;border-radius:20px;margin-top:6px;margin-left:31px}
.impact-h{background:#10b98112;color:var(--green);border:1px solid #10b98120}
.impact-m{background:#f0a50012;color:var(--gold);border:1px solid #f0a50020}

/* ── FIELD WORKER ── */
.fw-card{background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:14px}
.fw-success{background:#10b98115;border:1px solid #10b98130;border-radius:10px;padding:14px;text-align:center;color:var(--green);font-size:13px;font-weight:600;font-family:var(--font-head);display:none}

/* ── TELECALLER ── */
.tc-voter{padding:12px;background:var(--bg);border:1px solid var(--border);border-radius:10px;margin-bottom:8px;transition:border .2s}
.tc-voter:hover{border-color:var(--border2)}
.tc-name{font-size:13px;font-weight:700;color:var(--text);margin-bottom:3px}
.tc-meta{font-size:11px;color:var(--text3);margin-bottom:8px}
.tc-script{background:var(--s3);border-radius:7px;padding:10px;font-size:11px;color:var(--text2);line-height:1.6;margin-bottom:8px;display:none}

/* ── UPLOAD ── */
.drop-zone{border:2px dashed var(--border2);border-radius:12px;padding:30px;text-align:center;cursor:pointer;transition:all .2s;margin-bottom:12px}
.drop-zone:hover,.drop-zone.drag{border-color:var(--gold);background:#f0a50006}
.drop-icon{font-size:32px;margin-bottom:8px}
.drop-text{font-size:13px;color:var(--text3)}
.drop-sub{font-size:11px;color:var(--text4);margin-top:3px}

/* ── STATUS MESSAGES ── */
.ok{color:var(--green);font-size:11px;margin-top:6px}
.err{color:var(--red);font-size:11px;margin-top:6px}
.info{color:var(--text3);font-size:11px;margin-top:6px}
.hidden{display:none!important}
.spin{width:16px;height:16px;border:2px solid transparent;border-top-color:currentColor;border-radius:50%;animation:spin .7s linear infinite;display:inline-block;vertical-align:middle}

/* ── MOBILE ── */
@media(max-width:640px){
  .sidebar{position:fixed;left:-220px;top:0;bottom:0;z-index:100;transition:left .3s}
  .sidebar.mobile-open{left:0}
  .sidebar.collapsed{width:220px;min-width:220px}
  .mob-overlay{display:none;position:fixed;inset:0;background:#00000060;z-index:99}
  .mob-overlay.on{display:block}
  .mob-menu-btn{display:flex!important}
  .panel,.chat-panel{padding-bottom:70px}
  .g3{grid-template-columns:1fr 1fr}
  .g4{grid-template-columns:1fr 1fr}
  .stat-grid{grid-template-columns:1fr 1fr}
  .bubble{max-width:88%}
}
.mob-menu-btn{display:none;width:32px;height:32px;background:var(--s3);border:1px solid var(--border);border-radius:7px;align-items:center;justify-content:center;cursor:pointer;font-size:16px;flex-shrink:0}
</style>
</head>
<body>

<!-- ══ MOBILE OVERLAY ══ -->
<div class="mob-overlay" id="mob-overlay" onclick="closeMobMenu()"></div>

<!-- ══ LOGIN ══ -->
<div class="login-wrap" id="login-wrap">
  <div class="login-bg"></div>
  <div class="login-card">
    <div class="login-logo">
      <div class="ciq-mark">
        <div class="ciq-c">CIQ</div>
      </div>
      <div class="login-title">ConstituencyIQ</div>
      <div class="login-sub">AI-Powered Constituency Intelligence</div>
    </div>
    <div class="l-err" id="l-err"></div>
    <div class="l-group"><label class="l-label">Email</label><input class="l-input" type="email" id="l-email" placeholder="your@email.com" autocomplete="email"/></div>
    <div class="l-group"><label class="l-label">Password</label><input class="l-input" type="password" id="l-pass" placeholder="Enter password" autocomplete="current-password"/></div>
    <button class="l-btn" id="l-btn" onclick="doLogin()">Sign In</button>
    <div class="l-footer">Access provided by your campaign administrator<br><span style="color:var(--gold);font-weight:600">+91 9236427008</span> — WhatsApp for demo</div>
  </div>
</div>

<!-- ══ APP SHELL ══ -->
<div class="shell" id="shell">

<!-- SIDEBAR -->
<div class="sidebar" id="sidebar">
  <div class="sb-collapse" id="sb-toggle" onclick="toggleSidebar()">&#8249;</div>
  <div class="sb-head">
    <div class="sb-brand">
      <div class="sb-ciq"><div class="sb-c">CIQ</div></div>
      <div class="sb-name-wrap">
        <div class="sb-fullname">ConstituencyIQ</div>
        <div class="sb-tagline">Political Intelligence</div>
      </div>
    </div>
  </div>
  <div class="sb-user">
    <div class="sb-uname" id="sb-uname">Loading...</div>
    <div class="sb-urole" id="sb-urole"></div>
  </div>
  <div class="sb-scroll" id="sb-scroll">
    <!-- Nav built by JS based on role -->
  </div>
  <div class="sb-bottom">
    <button class="logout-btn" onclick="doLogout()"><span>&#128274;</span><span>Sign Out</span></button>
    <div class="data-badge" id="data-badge">No data</div>
  </div>
</div>

<!-- MAIN -->
<div class="main">

  <!-- TOPBAR -->
  <div class="topbar">
    <button class="mob-menu-btn" onclick="openMobMenu()">&#9776;</button>
    <div class="tb-left">
      <div class="tb-title" id="tb-title">Dashboard</div>
      <div class="tb-sub" id="tb-sub">ConstituencyIQ</div>
    </div>
    <div class="tb-right">
      <div class="theme-sw">
        <button class="theme-opt on" onclick="setTheme('default',this)">Consultant</button>
        <button class="theme-opt" onclick="setTheme('warroom',this)">War Room</button>
        <button class="theme-opt" onclick="setTheme('light',this)">Light</button>
      </div>
      <span class="pill pill-gold" id="tb-area" style="display:none"></span>
      <span class="pill pill-green" id="tb-rec" style="display:none"></span>
    </div>
  </div>

  <!-- ══ PANELS ══ -->

  <!-- HOME / SENTIMENT -->
  <div class="panel on" id="panel-home">
    <div class="stat-grid" id="home-stats"></div>
    <div class="g2" style="margin-bottom:12px">
      <div class="card card-accent">
        <div class="card-shine"></div>
        <div class="card-title">&#127919; Sentiment Meter</div>
        <div class="meter-wrap">
          <div class="meter-gauge">
            <svg viewBox="0 0 200 110" width="200" height="110">
              <defs>
                <linearGradient id="g-red" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" style="stop-color:#ef4444"/><stop offset="100%" style="stop-color:#f97316"/></linearGradient>
                <linearGradient id="g-yel" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" style="stop-color:#f97316"/><stop offset="100%" style="stop-color:#eab308"/></linearGradient>
                <linearGradient id="g-grn" x1="0%" y1="0%" x2="100%" y2="0%"><stop offset="0%" style="stop-color:#eab308"/><stop offset="100%" style="stop-color:#10b981"/></linearGradient>
              </defs>
              <path d="M 20 100 A 80 80 0 0 1 70 27" stroke="url(#g-red)" stroke-width="12" fill="none" stroke-linecap="round"/>
              <path d="M 70 27 A 80 80 0 0 1 130 27" stroke="url(#g-yel)" stroke-width="12" fill="none" stroke-linecap="round"/>
              <path d="M 130 27 A 80 80 0 0 1 180 100" stroke="url(#g-grn)" stroke-width="12" fill="none" stroke-linecap="round"/>
              <line id="needle" x1="100" y1="100" x2="100" y2="28" stroke="white" stroke-width="2.5" stroke-linecap="round" class="meter-needle"/>
              <circle cx="100" cy="100" r="6" fill="white"/>
            </svg>
            <div class="meter-score">
              <div class="meter-num" id="m-num" style="color:var(--gold)">--</div>
              <div class="meter-lbl">SENTIMENT</div>
            </div>
          </div>
          <div class="meter-status" id="m-status" style="color:var(--text3)">Loading...</div>
          <div class="meter-trend" id="m-trend"></div>
        </div>
        <div id="m-inputs" style="margin-top:10px"></div>
      </div>
      <div class="card">
        <div class="card-title">&#128202; Score Breakdown</div>
        <div id="score-breakdown"></div>
        <div style="margin-top:10px">
          <div class="card-title" style="margin-bottom:6px">&#129504; AI Insight</div>
          <div id="home-ai-insight" style="font-size:11px;color:var(--text3);line-height:1.7">Click Calculate to get AI analysis.</div>
        </div>
        <button class="btn btn-gold btn-sm" style="margin-top:10px" onclick="calcSentiment()" id="calc-btn">Calculate Score</button>
      </div>
    </div>
    <div class="card">
      <div class="card-title">&#128203; Ground Activity</div>
      <div class="g3" id="ground-stats"></div>
    </div>
  </div>

  <!-- DEMOGRAPHICS -->
  <div class="panel" id="panel-demo">
    <div class="card card-accent">
      <div class="card-shine"></div>
      <div class="card-title">&#127758; Constituency Demographics</div>
      <div class="demo-tabs" id="demo-tabs">
        <button class="demo-tab on" onclick="demoTab('religion',this)">Religion</button>
        <button class="demo-tab" onclick="demoTab('gender',this)">Gender</button>
        <button class="demo-tab" onclick="demoTab('caste',this)">Caste</button>
        <button class="demo-tab" onclick="demoTab('age',this)">Age Groups</button>
        <button class="demo-tab" onclick="demoTab('booth',this)">Booths</button>
      </div>
      <div class="demo-content on" id="demo-religion">
        <div class="chart-box"><canvas id="chart-religion" style="max-height:200px"></canvas></div>
        <div id="bars-religion"></div>
      </div>
      <div class="demo-content" id="demo-gender">
        <div class="chart-box"><canvas id="chart-gender" style="max-height:200px"></canvas></div>
        <div id="bars-gender"></div>
      </div>
      <div class="demo-content" id="demo-caste">
        <div class="chart-box"><canvas id="chart-caste" style="max-height:200px"></canvas></div>
        <div id="bars-caste"></div>
      </div>
      <div class="demo-content" id="demo-age">
        <div class="chart-box"><canvas id="chart-age" style="max-height:200px"></canvas></div>
        <div id="bars-age"></div>
      </div>
      <div class="demo-content" id="demo-booth">
        <div class="stat-grid" id="booth-stats"></div>
        <div class="tbl-wrap" style="margin-top:10px"><table id="booth-table"><thead><tr><th>Booth</th><th>Area</th><th>Total Voters</th><th>Male</th><th>Female</th><th>Turnout 2022</th></tr></thead><tbody id="booth-tbody"></tbody></table></div>
      </div>
    </div>
  </div>

  <!-- ISSUES -->
  <div class="panel" id="panel-issues">
    <div class="card card-accent">
      <div class="card-shine"></div>
      <div class="card-title">&#128293; Major Issues — Ranked</div>
      <div class="card-sub">AI-ranked by frequency and severity. Updated from field data and IVRS responses.</div>
      <div id="issues-list" style="margin-top:6px"></div>
    </div>
    <div class="card">
      <div class="card-title">&#128269; AI Issue Analysis</div>
      <button class="btn btn-gold btn-sm" onclick="analyseIssues()" id="issues-ai-btn">Analyse with AI</button>
      <div id="issues-ai-out" class="ai-out" style="display:none"></div>
    </div>
  </div>

  <!-- TRENDING -->
  <div class="panel" id="panel-trending">
    <div class="card card-accent">
      <div class="card-shine"></div>
      <div class="card-title">&#128200; Trending Now</div>
      <div class="card-sub">Real-time sentiment from social media + IVRS responses combined.</div>
      <div class="row" style="margin-bottom:12px">
        <span class="tag tg">Social Media</span>
        <span class="tag tb">IVRS Data</span>
        <span class="tag tgn">Field Reports</span>
      </div>
      <div id="trending-list"></div>
    </div>
    <div class="card">
      <div class="card-title">&#128202; Sentiment by Source</div>
      <canvas id="trend-chart" style="max-height:180px"></canvas>
    </div>
  </div>

  <!-- AI CHAT -->
  <div class="chat-panel" id="panel-chat">
    <div class="chat-top">
      <div class="chat-av">CIQ</div>
      <div>
        <div class="chat-nm">ConstituencyIQ Assistant</div>
        <div class="chat-st" id="chat-st">Ready</div>
      </div>
      <div class="lang-sw">
        <button class="lang-opt on" onclick="setLang('hi',this)" id="lang-hi">हिंदी</button>
        <button class="lang-opt" onclick="setLang('en',this)" id="lang-en">English</button>
      </div>
      <button class="btn btn-dim btn-xs" style="margin-left:8px" onclick="clearChat()">Clear</button>
    </div>
    <div class="chat-msgs" id="chat-msgs">
      <!-- Messages injected by JS -->
    </div>
    <div class="chips-row" id="chat-chips"></div>
    <div class="chat-in-row">
      <input class="chat-inp" id="chat-inp" placeholder="Kuch bhi poochho..." onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendMsg()}"/>
      <button class="send-btn" onclick="sendMsg()">&#10148;</button>
    </div>
  </div>

  <!-- ADMIN: AREA SELECTOR -->
  <div class="panel" id="panel-area">
    <div class="card card-accent">
      <div class="card-shine"></div>
      <div class="card-title">&#127758; Constituency Selector</div>
      <div class="card-sub">Select the political geography for this dashboard. All data filters to this selection.</div>
      <div class="g2" style="margin-bottom:10px">
        <div><label class="lbl">State</label>
          <select class="sel" id="sel-state" onchange="updateElectionLevel()">
            <option>Uttar Pradesh</option><option>Rajasthan</option><option>Maharashtra</option><option>Bihar</option><option>Madhya Pradesh</option><option>Gujarat</option><option>Karnataka</option><option>West Bengal</option><option>Tamil Nadu</option><option>Telangana</option>
          </select>
        </div>
        <div><label class="lbl">Election Level</label>
          <select class="sel" id="sel-level" onchange="updateConstituency()">
            <option value="mp">Lok Sabha (MP)</option>
            <option value="mla">Vidhan Sabha (MLA)</option>
            <option value="panchayat">Gram Panchayat</option>
          </select>
        </div>
      </div>
      <div class="g2" style="margin-bottom:10px">
        <div><label class="lbl">Constituency</label>
          <select class="sel" id="sel-const">
            <option>Lucknow West (#171)</option><option>Lucknow East (#172)</option><option>Lucknow Central (#173)</option><option>Lucknow Cantonment (#174)</option><option>Lucknow North (#175)</option>
          </select>
        </div>
        <div><label class="lbl">Ward / Booth (optional)</label>
          <select class="sel" id="sel-ward">
            <option value="">All Wards</option>
            <option>Ward 1 - Rajajipuram</option><option>Ward 2 - Alambagh</option><option>Ward 3 - Nishatganj</option><option>Ward 4 - Tulsi Nagar</option><option>Ward 5 - Sadar</option><option>Ward 6 - Aminabad</option><option>Ward 7 - Naka Hindola</option><option>Ward 8 - Vikas Nagar</option>
          </select>
        </div>
      </div>
      <button class="btn btn-gold" onclick="applyArea()">Apply Selection</button>
      <div id="area-st" class="ok" style="display:none">Area updated!</div>
    </div>
    <div class="card">
      <div class="card-title">&#9878; Current Selection</div>
      <div id="current-area" style="font-size:13px;color:var(--text2);line-height:1.8">
        <div><span style="color:var(--text3)">State:</span> <strong>Uttar Pradesh</strong></div>
        <div><span style="color:var(--text3)">Level:</span> <strong>Vidhan Sabha (MLA)</strong></div>
        <div><span style="color:var(--text3)">Constituency:</span> <strong style="color:var(--gold)">Lucknow West #171</strong></div>
        <div><span style="color:var(--text3)">Total Electors:</span> <strong>3,90,000</strong></div>
      </div>
    </div>
  </div>


async function getActions() {
  var btn = document.getElementById("actions-btn");
  btn.disabled = true; btn.textContent = "Generating...";
  try {
    var res = await api("actions", {voterData:G.rows, constituency:"Lucknow West", lang:G.lang});
    var parts = res.actions.split(/ACTION\s*\d+[:.]/i).filter(function(p) { return p.trim(); });
    var html = "";
    parts.forEach(function(p, i) {
      var lines = p.trim().split("\n").filter(function(l) { return l.trim(); });
      var title = lines[0] || ("Action " + (i+1));
      var body = lines.slice(1).join("\n");
      var isHigh = body.toLowerCase().indexOf("high") >= 0;
      html += '<div class="action-card">';
      html += '<div class="action-top">';
      html += '<div class="action-num">' + (i+1) + "</div>";
      html += '<div class="action-title">' + title + "</div>";
      html += "</div>";
      html += '<div class="action-body">' + body.replace(/\n/g,"<br>") + "</div>";
      html += '<div class="impact-tag impact-' + (isHigh?"h":"m") + '">' + (isHigh?"HIGH IMPACT":"MEDIUM IMPACT") + "</div>";
      html += "</div>";
    });
    document.getElementById("actions-list").innerHTML = html;
  } catch(e) { alert("Error: " + e.message); }
  btn.disabled = false; btn.textContent = "Regenerate";
}


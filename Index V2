// ════ TELECALLER ══════════════════════════════════════════════════════════
function renderTelecaller() {
  var myList = G.callsData.slice(0, 10);
  var done = myList.filter(function(c) { return c.status === "done"; }).length;
  var tcStats = [{v:myList.length,l:"Assigned"},{v:done,l:"Completed"},{v:myList.length-done,l:"Remaining"}];
  var tsHtml = "";
  tcStats.forEach(function(s) {
    tsHtml += "<div class=\"stat\"><div class=\"stat-val\">" + s.v + "</div><div class=\"stat-lbl\">" + s.l + "</div></div>";
  });
  document.getElementById("tc-stats").innerHTML = tsHtml;
  var smap3 = {done:"cs-done",busy:"cs-busy",miss:"cs-miss",pend:"cs-pend"};
  var slabel3 = {done:"Done",busy:"Busy",miss:"No Answer",pend:"Pending"};
  var tcHtml = "";
  myList.forEach(function(c, i) {
    tcHtml += "<div class=\"tc-voter\">";
    tcHtml += "<div class=\"tc-name\">" + c.name + "</div>";
    tcHtml += "<div class=\"tc-meta\">" + c.ward + " &middot; " + c.phone + " &middot; Issue: " + c.issue + "</div>";
    tcHtml += "<div class=\"tc-script\" id=\"tcs-" + i + "\">Loading script...</div>";
    tcHtml += "<div class=\"row\">";
    tcHtml += "<span class=\"call-status " + smap3[c.status] + "\">" + slabel3[c.status] + "</span>";
    tcHtml += "<button class=\"btn btn-dim btn-xs\" onclick=\"toggleTCScript(" + i + ")\">View Script</button>";
    tcHtml += "<button class=\"btn btn-green btn-xs\" onclick=\"markCall(" + i + ",\'done\')\">Done</button>";
    tcHtml += "<button class=\"btn btn-red btn-xs\" onclick=\"markCall(" + i + ",\'miss\')\">No Answer</button>";
    tcHtml += "</div></div>";
  });
  document.getElementById("tc-list").innerHTML = tcHtml;;
}

function toggleTCScript(i) {
  var el = document.getElementById("tcs-" + i);
  if (!el) return;
  if (el.style.display === "block") { el.style.display = "none"; return; }
  var c = G.callsData[i];
  el.style.display = "block";
  el.textContent = "Namaste " + c.name.split(" ")[0] + " ji! Main ConstituencyIQ se bol raha hoon. " + c.issue + " ke baare mein aapka kya kehna hai? Hamare candidate ne is par kaam karne ka vaada kiya hai...";
}

function markCall(i, status) {
  if (G.callsData[i]) G.callsData[i].status = status;
  renderTelecaller();
}


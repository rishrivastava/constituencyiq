function updateMeter(score) {
  document.getElementById("m-num").textContent = score;
  var angle = -90 + (score / 100) * 180;
  var rad = angle * Math.PI / 180;
  var x2 = 100 + 72 * Math.sin(rad);
  var y2 = 100 - 72 * Math.cos(rad);
  document.getElementById("needle").setAttribute("x2", x2.toFixed(1));
  document.getElementById("needle").setAttribute("y2", y2.toFixed(1));
  var col = score >= 70 ? "#10b981" : score >= 45 ? "#f0a500" : "#ef4444";
  document.getElementById("m-num").style.color = col;
  var labels = ["Critical","Vulnerable","Competitive","Positive Momentum","Strong Wave"];
  var li = score >= 80 ? 4 : score >= 60 ? 3 : score >= 40 ? 2 : score >= 20 ? 1 : 0;
  document.getElementById("m-status").textContent = labels[li];
  document.getElementById("m-status").style.color = col;
  document.getElementById("m-trend").textContent = "7-day trend: +4 points &#8679;";
  var inputs = [
    {l:"Field Survey", v:72, c:"#10b981"},
    {l:"IVRS Calls", v:61, c:"#2563eb"},
    {l:"Social Media", v:58, c:"#7c3aed"},
    {l:"Issue Resolution", v:45, c:"#f0a500"}
  ];
  var miHtml = "";
  inputs.forEach(function(inp) {
    miHtml += "<div class=\"dbar\"><div class=\"dbar-lbl\">" + inp.l + "</div><div class=\"dbar-track\"><div class=\"dbar-fill\" style=\"width:" + inp.v + "%;background:" + inp.c + "\"></div></div><div class=\"dbar-val\">" + inp.v + "</div></div>";
  });
  document.getElementById("m-inputs").innerHTML = miHtml;
}

function renderScoreBreakdown(s) {
  var factors = [
    {l:"Voter Support", v:72, c:"#10b981"},
    {l:"Awareness", v:65, c:"#2563eb"},
    {l:"Past Turnout", v:68, c:"#f0a500"},
    {l:"Community Alignment", v:55, c:"#7c3aed"}
  ];
  var html = "";
  factors.forEach(function(f) {
    html += "<div style=\"margin-bottom:9px\">";
    html += "<div style=\"display:flex;justify-content:space-between;margin-bottom:3px\">";
    html += "<span style=\"font-size:11px;color:var(--text2)\">" + f.l + "</span>";
    html += "<span style=\"font-size:11px;font-weight:700;color:" + f.c + "\">" + f.v + "%</span>";
    html += "</div>";
    html += "<div class=\"prog\"><div class=\"prog-fill\" style=\"width:" + f.v + "%;background:" + f.c + "\"></div></div>";
    html += "</div>";
  });
  document.getElementById("score-breakdown").innerHTML = html;
}

async function calcSentiment() {
  var btn = document.getElementById("calc-btn");
  btn.disabled = true; btn.textContent = "Calculating...";
  try {
    var res = await api("score", {voterData: G.rows});
    updateMeter(res.score);
    renderScoreBreakdown(res.score);
    var el = document.getElementById("home-ai-insight");

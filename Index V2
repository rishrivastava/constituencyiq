function showLogin() {
  document.getElementById("login-wrap").style.display = "flex";
  document.getElementById("shell").classList.remove("on");
}
function showApp() {
  document.getElementById("login-wrap").style.display = "none";
  document.getElementById("shell").classList.add("on");
}

async function doLogin() {
  var email = document.getElementById("l-email").value.trim();
  var pass = document.getElementById("l-pass").value;
  var err = document.getElementById("l-err");
  var btn = document.getElementById("l-btn");
  if (!email || !pass) { showLErr("Please enter email and password"); return; }
  btn.disabled = true;
  btn.innerHTML = '<span class="spin"></span> Signing in...';
  err.style.display = "none";
  try {
    await auth.signInWithEmailAndPassword(email, pass);
  } catch(e) {
    var m = "Invalid email or password";
    if (e.code === "auth/user-not-found") m = "Account not found. Contact your admin.";
    if (e.code === "auth/wrong-password") m = "Wrong password.";
    if (e.code === "auth/too-many-requests") m = "Too many attempts. Try later.";
    showLErr(m);
    btn.disabled = false;
    btn.innerHTML = "Sign In";
  }
}
document.getElementById("l-pass").addEventListener("keydown", function(e) {
  if (e.key === "Enter") doLogin();
});
function showLErr(m) {
  var el = document.getElementById("l-err");
  el.textContent = m; el.style.display = "block";
}
async function doLogout() { await auth.signOut(); showLogin(); }

// ════ TOKEN REFRESH ══════════════════════════════════════════════════════
async function refreshToken() {
  if (G.user) G.token = await G.user.getIdToken(true);
}

// ════ API CALL ════════════════════════════════════════════════════════════
async function api(ep, data) {
  await refreshToken();
  var r = await fetch(BACKEND + "/api/" + ep, {
    method: "POST",
    headers: { "Content-Type": "application/json", "Authorization": "Bearer " + G.token },
    body: JSON.stringify(data)
  });
  var j = await r.json();
  if (!r.ok) throw new Error(j.error || "Request failed " + r.status);
  return j;
}

